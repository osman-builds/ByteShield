<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ByteSheild.AboutPage"
             BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}">

    <ScrollView BackgroundColor="{AppThemeBinding Light=White, Dark=#0B1426}">
        <Grid HorizontalOptions="Center" MaximumWidthRequest="600">
            <StackLayout VerticalOptions="Start" HorizontalOptions="Fill" Spacing="25" Padding="20">
                <Image Source="shield_icon.svg" WidthRequest="120" HeightRequest="120" HorizontalOptions="Center" />
                <Label Text="ByteShield" FontSize="32" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#2A2A2A, Dark=White}" HorizontalOptions="Center" Margin="0,0,0,-15" />

                <Label x:Name="VersionLabel" FontSize="14" TextColor="{AppThemeBinding Light=#757575, Dark=#A0A0A0}" HorizontalOptions="Center" Margin="0,0,0,10" />

                <Border BackgroundColor="{AppThemeBinding Light=#F8F9FA, Dark=#1E2A42}" StrokeThickness="0" Padding="20" Margin="0,0,0,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Opacity="{AppThemeBinding Light=0.1, Dark=0.3}" Radius="8" />
                    </Border.Shadow>
                    <StackLayout Spacing="8">
                        <Label Text="Developer: Abdullahi Ahmed Osman" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#333333, Dark=White}" HorizontalOptions="Center" />
                        <Label Text="Mobile software engineer focused on secure .NET MAUI applications, local-first architecture, authentication flows, and polished cross-platform UX." FontSize="14" TextColor="{AppThemeBinding Light=#666666, Dark=#B0B0B0}" FontAttributes="Italic" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E0E0E0, Dark=#3A4A6A}" Margin="20,5,20,5" />
                        <Label Text="Focus Areas: .NET MAUI, C#, XAML, secure local storage, biometric auth, and mobile-first product design" FontSize="13" TextColor="{AppThemeBinding Light=#888888, Dark=#909090}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    </StackLayout>
                </Border>

                <StackLayout Spacing="12" Margin="0,20,0,0">
                    <Label Text="Settings" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,0,0,5" />

                    <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Dark Mode" VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Switch x:Name="ThemeSwitch" Grid.Column="1" Toggled="OnThemeSwitchToggled" OnColor="#00D4AA" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSetupPasscodeTapped" />
                        </Border.GestureRecognizers>
                        <Grid>
                            <Label Text="Set up App Passcode" VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Text=">" HorizontalOptions="End" VerticalOptions="Center" TextColor="#00D4AA" FontAttributes="Bold" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="#FFEbee" StrokeThickness="0" Padding="15" Margin="0,15,0,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSelfDestructTapped" />
                        </Border.GestureRecognizers>
                        <Grid>
                            <Label Text="Self-Destruct" VerticalOptions="Center" FontAttributes="Bold" TextColor="#D32F2F" />
                            <Label Text="⚠" HorizontalOptions="End" VerticalOptions="Center" TextColor="#D32F2F" FontAttributes="Bold" />
                        </Grid>
                    </Border>

                    <Label Text="About" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" Margin="0,15,0,5" />

                    <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPrivacyPolicyTapped" />
                        </Border.GestureRecognizers>
                        <Grid>
                            <Label Text="Privacy Policy" VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Text=">" HorizontalOptions="End" VerticalOptions="Center" TextColor="#00D4AA" FontAttributes="Bold" />
                        </Grid>
                    </Border>

                    <Border BackgroundColor="{AppThemeBinding Light=#F0F0F0, Dark=#162236}" StrokeThickness="0" Padding="15">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnOpenSourceLicensesTapped" />
                        </Border.GestureRecognizers>
                        <Grid>
                            <Label Text="MIT License" VerticalOptions="Center" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Label Text=">" HorizontalOptions="End" VerticalOptions="Center" TextColor="#00D4AA" FontAttributes="Bold" />
                        </Grid>
                    </Border>
                </StackLayout>
            </StackLayout>
        </Grid>
    </ScrollView>

</ContentPage>



